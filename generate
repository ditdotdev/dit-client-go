#!/bin/bash
set -euo pipefail

# Pin to a specific openapi-generator-cli version so regenerations are reproducible.
# v7.22.0 is the latest stable as of this upgrade (https://hub.docker.com/r/openapitools/openapi-generator-cli/tags).
#
# Custom mustache templates live under templates/. Keep them MINIMAL —
# every override is a maintenance liability when the generator's stock
# templates evolve. See chore/upgrade-openapi-generator-v7 PR for the
# audit + re-derivation that produced the current set.

# Step 1: generate via the openapi-generator container.
#
# We deliberately do NOT pass --enable-post-process-file: the
# openapitools/openapi-generator-cli image is a JVM image with no Go
# toolchain, so any GO_POST_PROCESS_FILE invocation inside the container
# fails with "Cannot run program /usr/local/bin/gofmt". We run gofmt on
# the host after generation instead — see step 2.
docker run --rm -v ${PWD}:/local \
    openapitools/openapi-generator-cli:v7.22.0 \
    generate -i /local/datadatdat.yml -g go -o /local -t /local/templates \
    --additional-properties=packageName=datadatdatclient,withGoCodegenComment=true,apiNameSuffix=Api \
    --git-user-id=datadatdat --git-repo-id=datadatdat-client-go

# Step 2: gofmt the emitted Go files on the host.
# The repo's Code Quality CI runs `gofmt -s -l .` and fails on any output,
# so emitted code MUST be gofmt-clean before we commit it.
#
# Templates emit modern Go doc-comment style ("  - @param") to avoid the
# non-idempotent gofmt migration from v4-era " * @param" style that would
# otherwise require running gofmt twice.
gofmt -s -w .
